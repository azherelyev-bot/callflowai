# ServiceTitan OAuth credentials
SERVICETITAN_CLIENT_ID=your-client-id-here
SERVICETITAN_CLIENT_SECRET=your-client-secret-here
SERVICETITAN_TENANT_ID=your-tenant-id-here

# Set to "true" to simulate ServiceTitan responses without live credentials
MOCK_MODE=true

# Database — PostgreSQL connection string
# Railway provisions this automatically when you add a Postgres plugin
# For local dev, SQLite is used as fallback if not set
DATABASE_URL=postgresql://user:password@localhost:5432/callflowai

# Flask
FLASK_SECRET_KEY=generate-a-random-secret-here

# Vapi voice agent
VAPI_API_KEY=your-vapi-api-key-here

# Railway sets this automatically — do not set manually
# PORT=
